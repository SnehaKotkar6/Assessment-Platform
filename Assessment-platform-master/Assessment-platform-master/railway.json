{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn clean package -DskipTests"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "java -jar target/coding-assessment-1.0.0.jar --server.port=$PORT",
    "healthcheckPath": "/",
    "sleepApplication": false
  }
}
